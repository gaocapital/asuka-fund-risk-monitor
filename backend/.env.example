# Asuka Fund — Environment Variables
# Copy to .env and fill in your values. .env is gitignored.

# EDINET API (Japan Financial Services Agency)
# Free key: register at https://disclosure.edinet-fsa.go.jp/api/v2/
EDINET_API_KEY=

# Bloomberg Terminal API (optional — primary price source)
# Requires Bloomberg Terminal session running on this machine
# Set to 1 to enable, 0 to skip
BLOOMBERG_ENABLED=0

# Interactive Brokers Gateway (optional — fallback price source)
# Default IB Gateway port is 4001 (live) or 4002 (paper)
IB_GATEWAY_HOST=localhost
IB_GATEWAY_PORT=4001
IB_CLIENT_ID=1

# Yahoo Finance JP (no key required, used as final fallback)
# No env var needed.

# DuckDuckGo search (no key required, used by news_scan.py)
# No env var needed.

# Output paths (defaults shown)
DASHBOARD_OUTPUT_DIR=output
DASHBOARD_STATE_DIR=state
DASHBOARD_LOGS_DIR=logs

# Override "today" for testing/backfill (ISO date YYYY-MM-DD, leave blank for actual today)
DASHBOARD_TODAY=

# Notification settings (optional)
# SMTP for email alerts on HIGH severity events
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
ALERT_EMAIL_TO=
